    "scanner",
    "bugs",
    "vulnerability",
    "performance",
    "code-quality",
    "skill"
  ],
  "author": "Alp Yenigun <alp@normbitkisel.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/alpyenigun/eliniscan"
  },
  "homepage": "https://github.com/alpyenigun/eliniscan#readme",
  "bugs": {
    "url": "https://github.com/alpyenigun/eliniscan/issues"
  },
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/install.js"
  },
  "bin": {
    "eliniscan": "./scripts/cli.js"
  },
  "files": [
    "commands/",
    "workflows/",
